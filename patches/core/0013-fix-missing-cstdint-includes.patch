From 00ffb8c26d91643f821b442bd7b3628ce2538da3 Mon Sep 17 00:00:00 2001
From: meator <meator.dev@gmail.com>
Date: Mon, 29 Jun 2026 15:32:42 +0200
Subject: [PATCH] fix missing cstdint includes

Source:
https://github.com/msys2/MINGW-packages/blob/a43788529cff7aa515701ee5b2ed83a282863fa6/mingw-w64-android-tools/0005-missing-includes.patch
---
 fastboot/tcp.cpp | 1 +
 fastboot/udp.h   | 1 +
 fastboot/usb.h   | 1 +
 3 files changed, 3 insertions(+)

diff --git a/fastboot/tcp.cpp b/fastboot/tcp.cpp
index dca306f5..b00d1198 100644
--- a/fastboot/tcp.cpp
+++ b/fastboot/tcp.cpp
@@ -30,6 +30,7 @@
 
 #include <android-base/parseint.h>
 #include <android-base/stringprintf.h>
+#include <cstdint>
 
 namespace tcp {
 
diff --git a/fastboot/udp.h b/fastboot/udp.h
index 8d37b841..fb598a23 100644
--- a/fastboot/udp.h
+++ b/fastboot/udp.h
@@ -30,6 +30,7 @@
 
 #include <memory>
 #include <string>
+#include <cstdint>
 
 #include "socket.h"
 #include "transport.h"
diff --git a/fastboot/usb.h b/fastboot/usb.h
index d85cb818..381e6419 100644
--- a/fastboot/usb.h
+++ b/fastboot/usb.h
@@ -30,6 +30,7 @@
 
 #include <functional>
 #include <memory>
+#include <cstdint>
 
 #include "transport.h"
 
